  <div id="toast" style="position:fixed;bottom:20px;right:20px;background:#fff;color:var(--dark);padding:16px 24px;border-radius:12px;box-shadow:0 10px 30px rgba(0,0,0,.2);display:none;z-index:3000;max-width:350px;animation:slideIn .3s ease;border-left:4px solid var(--primary)">
    <div style="display:flex;align-items:start;gap:12px">
      <i class="fas fa-check-circle" style="color:var(--success);font-size:1.3rem;margin-top:2px"></i>
