  <!-- ===== CORE JAVASCRIPT ===== -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    // ==================== CONFIG ====================
    const CONFIG = {
      appName: 'Makedon Eco World',
      contactEmail: 'makedonecoworld@outlook.com',
      apiBaseUrl: '/api/v1',
      pointsPerItem: 1,
      baseValueEur: 0.018,
      platformFeePercent: 0.03,
      minPayout: { MK: 100, DE: 5, NO: 50, US: 3, global: 5 },
      exchangeRates: { MKD: 61.5, EUR: 1, USD: 1.08, NOK: 11.2 },
      supportedLanguages: ['mk', 'en', 'sq', 'sr', 'bg'],
      levels: [
        { name: 'Еко-Новач', threshold: 0, icon: '🌱' },
        { name: 'Зелен Херој', threshold: 50, icon: '🌿' },
        { name: 'Планетарен Чувач', threshold: 200, icon: '🌳' },
        { name: 'Глобален Лидер', threshold: 500, icon: '🌍' }
      ]
    };

    // ==================== STATE ====================
    const state = {
      currentUser: null,
      ecoPoints: 0,
      scannedItems: [],
      agents: { qwen: null, gpt: null, claude: null, harvey: null },
      cameraStream: null,
      map: null
    };

    // ==================== AGENT MOCKS ====================
    class QwenAgent {
      constructor(config) { this.config = config; }
      async verifyItem(imageData, metadata) {
        await new Promise(r => setTimeout(r, 1200 + Math.random()*800));
        const valid = Math.random() > 0.08;
        const types = ['plastic','glass','aluminum'];
        const values = { plastic: 6, glass: 10, aluminum: 8 };
        const type = types[Math.floor(Math.random()*3)];
        return {
          is_valid: valid,
          item_type: valid ? type : 'invalid',
          barcode_detected: valid ? `BAR${Math.floor(Math.random()*1e6)}` : null,
          confidence_score: valid ? (0.87 + Math.random()*0.12).toFixed(2) : 0,
          deposit_value_mkd: valid ? values[type] : 0,
          eco_points_earned: valid ? CONFIG.pointsPerItem : 0,
          message_mk: valid ? `✅ Одлично! Добивте 1 EcoPoint за ова ${type === 'plastic' ? 'пластично шише' : type === 'glass' ? 'стаклено шише' : 'лименка'}.` : '❌ Овој предмет не е прифатлив. Обидете се со друг.',
          next_suggestion: valid ? ['scan_more', 'view_points', 'invite_friend'][Math.floor(Math.random()*3)] : 'try_again'
        };
      }
    }

    class GPTAgent {
      constructor(config) { this.config = config; this.userContext = config.userContext || {}; }
      async generateResponse(userMessage, history) {
        await new Promise(r => setTimeout(r, 600 + Math.random()*400));
        const points = this.userContext.total_points || 0;
        const level = CONFIG.levels.slice().reverse().find(l => points >= l.threshold) || CONFIG.levels[0];
        const nextLevel = CONFIG.levels.find(l => l.threshold > points);
        const progress = nextLevel ? Math.min(100, Math.round((points - level.threshold) / (nextLevel.threshold - level.threshold) * 100)) : 100;
        const messages = [
          `Здраво ${this.userContext.name || 'Пријателе'}! 🌱`,
          `Твоето ниво: ${level.icon} ${level.name}`,
          `Имаш ${points} EcoPoints`,
          nextLevel ? `Уште ${nextLevel.threshold - points} поени до ${nextLevel.name}!` : 'Честитки, го достигна највисокото ниво! 🎉',
          '',
          'Што сакаш да направиш денес?',
          '• 📸 Скенрај ново шише',
          '• 💰 Конвертирај поени во пари',
          '• 🎁 Види ги наградите',
          '• 👥 Покани пријател'
        ].join('\n');
        return {
          message: messages,
          suggested_action: { type: 'scan', label: 'Скенрај ново шише →', deep_link: 'ecopoints://scan' },
          gamification_trigger: {
            show_confetti: points > 0 && points % 50 === 0,
            badge_unlocked: points === 50 ? '🏆 Прв Херој' : points === 200 ? '🌟 Планетарен Шампион' : null,
            level_progress: { current: level.name, next: nextLevel?.name || 'MAX', percent: progress }
          }
        };
      }
    }

    class ClaudeAgent {
      constructor(config) { this.regulations = this._loadRegulations(); }
      _loadRegulations() {
        return {
          MK: { deposit_active: false, min_age: 16, data_retention_days: 730, tax_rate: 0, currency: 'MKD' },
          DE: { deposit_active: true, min_age: 18, data_retention_days: 2555, tax_rate: 0.19, currency: 'EUR' },
          NO: { deposit_active: true, min_age: 13, data_retention_days: 1825, tax_rate: 0.22, currency: 'NOK' },
          US: { deposit_active: false, min_age: 18, data_retention_days: 1825, tax_rate: 0.15, currency: 'USD' }
        };
      }
      async checkCompliance(countryCode) {
        await new Promise(r => setTimeout(r, 500));
        const reg = this.regulations[countryCode] || this.regulations.MK;
        return {
          compliant: true,
          recommendations: reg.deposit_active ? [] : ['Размисли за партнерство со локални рециклери наместо депозит модел'],
          min_age: reg.min_age,
          tax_rate: reg.tax_rate,
          currency: reg.currency,
          legal_note: `Усогласено со регулативите во ${countryCode}`
        };
      }
    }

    class HarveyAgent {
      constructor(config) { this.stripeKey = config.stripeKey; this.taxDB = config.taxDB || {}; }
      async calculatePayout(userId, ecoPoints, targetCurrency) {
        await new Promise(r => setTimeout(r, 1000));
        const grossEur = ecoPoints * CONFIG.baseValueEur;
        const fee = grossEur * CONFIG.platformFeePercent;
        const userCountry = 'MK';
        const taxRate = this.taxDB[userCountry]?.payout_tax_rate || 0;
        const tax = (grossEur - fee) * taxRate;
        const netEur = grossEur - fee - tax;
        const rate = CONFIG.exchangeRates[targetCurrency] || 1;
        const netAmount = netEur * rate;
        const minPayout = CONFIG.minPayout[userCountry] || CONFIG.minPayout.global;
        if (netAmount < minPayout) {
          return { 
            status: 'PENDING_THRESHOLD', 
            message_mk: `💰 Потребни се уште ${(minPayout - netAmount).toFixed(2)} ${targetCurrency} за исплата`, 
            current_net: netAmount.toFixed(2), 
            threshold: minPayout,
            points_needed: Math.ceil((minPayout - netAmount) / (CONFIG.baseValueEur * rate))
          };
        }
        return {
          status: 'READY_FOR_PAYOUT',
          breakdown: { gross: (grossEur * rate).toFixed(2), fee: (fee * rate).toFixed(2), tax: (tax * rate).toFixed(2), net: netAmount.toFixed(2), currency: targetCurrency },
          payout_intent_id: `pi_${Date.now()}_${Math.random().toString(36).substr(2,9)}`,
          estimated_arrival: '1-3 работни дена',
          compliance_note: 'Трансакцијата е комплајантна со регулативите во ' + userCountry
        };
      }
    }

    // ==================== CORE FUNCTIONS ====================
    function initAgents() {
      state.agents.qwen = new QwenAgent({ apiKey: 'mock-key', region: 'balkans' });
      state.agents.gpt = new GPTAgent({ apiKey: 'mock-key', userContext: { name: 'Санде', total_points: state.ecoPoints, country: 'MK', language: 'mk' } });
      state.agents.claude = new ClaudeAgent({ apiKey: 'mock-key' });
      state.agents.harvey = new HarveyAgent({ stripeKey: 'mock-stripe-key', taxDB: { MK: { payout_tax_rate: 0 } } });
      console.log('🤖 AI Agents initialized for', CONFIG.appName);
    }

    function initMap() {
      if (state.map) return;
      state.map = L.map('map').setView([41.9973, 21.4280], 13);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors | Makedon Eco World'
      }).addTo(state.map);
      const markers = [
        { coords: [41.9973, 21.4280], title: 'Пакомак Центар', type: 'pakomak' },
        { coords: [42.0050, 21.4350], title: 'Веро Супермаркет', type: 'store' },
        { coords: [41.9920, 21.4200], title: 'Автомат за Шишиња', type: 'vending' },
        { coords: [42.0100, 21.4400], title: 'Скопје Сити Мол', type: 'mall' }
      ];
      const icons = {
        pakomak: L.divIcon({ className: 'custom-marker', html: '<div style="background:#2ecc71;width:20px;height:20px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.2)"></div>' }),
        store: L.divIcon({ className: 'custom-marker', html: '<div style="background:#3498db;width:20px;height:20px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.2)"></div>' }),
        vending: L.divIcon({ className: 'custom-marker', html: '<div style="background:#f39c12;width:20px;height:20px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.2)"></div>' }),
        mall: L.divIcon({ className: 'custom-marker', html: '<div style="background:#9b59b6;width:20px;height:20px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.2)"></div>' })
      };
      markers.forEach(m => {
        L.marker(m.coords, { icon: icons[m.type] }).addTo(state.map)
          .bindPopup(`<strong>${m.title}</strong><br><small>Отворено 08:00-22:00</small>`);
      });
      if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(pos => {
          L.marker([pos.coords.latitude, pos.coords.longitude], {
            icon: L.divIcon({ className: 'user-marker', html: '<div style="background:#e74c3c;width:16px;height:16px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.3)"></div>' })
          }).addTo(state.map).bindPopup('📍 Ти си тука').openPopup();
          state.map.setView([pos.coords.latitude, pos.coords.longitude], 14);
        }, () => {}, { enableHighAccuracy: true, timeout: 5000 });
      }
    }

    async function startScan() {
      openModal('scanModal');
      document.getElementById('scan-result').classList.remove('active', 'success', 'error');
      document.getElementById('captureBtn').disabled = false;
      document.getElementById('captureBtn').innerHTML = '<i class="fas fa-camera"></i> <span data-translate-key="btn_capture">Снимка и Верификација</span>';
      if (navigator.mediaDevices?.getUserMedia) {
        try {
          state.cameraStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } } });
          const video = document.getElementById('camera-preview');
          video.srcObject = state.cameraStream;
          video.classList.add('active');
          video.play().catch(() => {});
        } catch (err) {
          console.warn('Camera access denied:', err);
          document.getElementById('scan-message').textContent = '📷 Камерата не е достапна. Можеш да пратиш слика од галеријата.';
          document.getElementById('scan-result').classList.add('active');
        }
      } else {
        document.getElementById('scan-message').textContent = '⚠️ Твојот браузер не поддржува камера. Користи мобилен уред.';
        document.getElementById('scan-result').classList.add('active');
      }
    }

    async function captureAndVerify() {
      const video = document.getElementById('camera-preview');
      if (!video.srcObject) { showToast('Грешка', 'Камерата не е активирана. Обиди се повторно.', 'error'); return; }
      const canvas = document.createElement('canvas');
      canvas.width = video.videoWidth || 1280; canvas.height = video.videoHeight || 720;
      canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);
      const imageData = canvas.toDataURL('image/jpeg', 0.85);
      document.getElementById('captureBtn').disabled = true;
      document.getElementById('captureBtn').innerHTML = '<span class="loading loading-dark"></span> <span data-translate-key="btn_verifying">Верификација во тек...</span>';
      try {
        const verification = await state.agents.qwen.verifyItem(imageData, { timestamp: new Date().toISOString(), location: navigator.geolocation ? 'detected' : 'unknown' });
        const resultEl = document.getElementById('scan-result'), msgEl = document.getElementById('scan-message'), ptsEl = document.getElementById('scan-points');
        msgEl.textContent = verification.message_mk;
        ptsEl.textContent = verification.is_valid ? `+${verification.eco_points_earned} EcoPoint` : '';
        resultEl.className = `active ${verification.is_valid ? 'success' : 'error'}`;
        if (verification.is_valid) {
          state.ecoPoints += verification.eco_points_earned;
          document.getElementById('userPoints').textContent = state.ecoPoints;
          document.getElementById('resultPoints').textContent = state.ecoPoints;
          updateLevelProgress();
          const celebration = await state.agents.gpt.generateResponse(`Скенирав успешно!`, []);
          if (celebration.gamification_trigger.show_confetti) triggerConfetti();
          if (celebration.gamification_trigger.badge_unlocked) showToast('🏆 Нов Беџ!', `Освоивте: ${celebration.gamification_trigger.badge_unlocked}`, 'success');
          document.getElementById('scan-next-actions').innerHTML = `<button class="btn btn-primary" onclick="startScan()" style="padding:8px 16px;font-size:.9rem"><i class="fas fa-redo"></i> <span data-translate-key="btn_scan_again">Скенрај уште</span></button><button class="btn btn-outline" onclick="closeModal('scanModal');scrollToSection('financial')" style="padding:8px 16px;font-size:.9rem"><i class="fas fa-coins"></i> <span data-translate-key="btn_view_points">Види Поени</span></button>`;
          showToast('Успешно!', verification.message_mk, 'success');
        } else {
          document.getElementById('scan-next-actions').innerHTML = `<button class="btn btn-primary" onclick="startScan()" style="padding:8px 16px;font-size:.9rem"><i class="fas fa-redo"></i> <span data-translate-key="btn_retry">Обиди се повторно</span></button>`;
        }
      } catch (error) {
        console.error('Scan error:', error);
        document.getElementById('scan-message').textContent = '❌ Се појави грешка при верификација. Обидете се повторно.';
        document.getElementById('scan-result').classList.add('active', 'error');
        showToast('Грешка', 'Проблем со верификацијата. Провери ја интернет врската.', 'error');
      } finally {
        document.getElementById('captureBtn').disabled = false;
        document.getElementById('captureBtn').innerHTML = '<i class="fas fa-camera"></i> <span data-translate-key="btn_capture">Снимка и Верификација</span>';
      }
    }

    function triggerConfetti() {
      const colors = ['#2ecc71', '#3498db', '#f39c12', '#e74c3c', '#9b59b6', '#1abc9c', '#34495e'];
      const container = document.body;
      for (let i = 0; i < 80; i++) {
        const conf = document.createElement('div');
        conf.className = 'confetti';
        conf.style.left = Math.random() * 100 + 'vw';
        conf.style.background = colors[Math.floor(Math.random() * colors.length)];
        conf.style.animationDuration = (2.5 + Math.random() * 2) + 's';
        conf.style.animationDelay = Math.random() * 0.5 + 's';
        conf.style.width = (6 + Math.random() * 8) + 'px';
        conf.style.height = conf.style.width;
        if (Math.random() > 0.6) conf.style.borderRadius = '50%';
        if (Math.random() > 0.8) conf.style.transform = 'rotate(' + Math.random() * 360 + 'deg)';
        container.appendChild(conf);
        setTimeout(() => conf.remove(), 5000);
      }
    }

    function updateLevelProgress() {
      const points = state.ecoPoints;
      const currentLevel = CONFIG.levels.slice().reverse().find(l => points >= l.threshold) || CONFIG.levels[0];
      const nextLevel = CONFIG.levels.find(l => l.threshold > points);
      const progress = nextLevel ? Math.min(100, Math.round((points - currentLevel.threshold) / (nextLevel.threshold - currentLevel.threshold) * 100)) : 100;
      document.getElementById('levelProgress').textContent = progress + '%';
      document.getElementById('progressBar').style.width = progress + '%';
      document.querySelectorAll('.level-badge').forEach(b => b.classList.remove('active'));
      const activeBadge = Array.from(document.querySelectorAll('.level-badge')).find(b => b.querySelector('.level-name').textContent === currentLevel.name);
      if (activeBadge) activeBadge.classList.add('active');
    }

    function closeModal(modalId) {
      document.getElementById(modalId).classList.remove('active');
      if (state.cameraStream) { state.cameraStream.getTracks().forEach(track => track.stop()); state.cameraStream = null; }
    }
    function openModal(modalId) { document.getElementById(modalId).classList.add('active'); if (modalId === 'scanModal') initMap(); }
    function handleLogin(e) {
      e.preventDefault();
      const email = document.getElementById('email').value;
      state.currentUser = { id: 'user_' + Date.now(), name: email.split('@')[0], email: email, country: 'MK', language: 'mk' };
      closeModal('loginModal');
      showToast('Добредојде!', `Здраво, ${state.currentUser.name}! 🌱 Почни со собирање.`, 'success');
      updateLevelProgress();
    }
    function showToast(title, message, type = 'success') {
      const toast = document.getElementById('toast');
      document.getElementById('toast-title').textContent = title;
      document.getElementById('toast-message').textContent = message;
      toast.style.borderLeftColor = type === 'success' ? 'var(--success)' : type === 'error' ? 'var(--danger)' : 'var(--accent)';
      toast.style.display = 'block';
      setTimeout(() => { toast.style.display = 'none'; }, 4000);
    }
    function scrollToSection(id) { document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' }); }
    function scrollToTop() { window.scrollTo({ top: 0, behavior: 'smooth' }); }
    function downloadSpecs() {
      const specs = `# Makedon Eco World – Технички Спецификации
## Контакти: ${CONFIG.contactEmail}
## API Base: ${CONFIG.apiBaseUrl}
## AI Агенти: Qwen (верификација), GPT (конверзација), Claude (комплајанса), Harvey (финансии)
## Финансиски: 1 сисе = 1 EcoPoint = €${CONFIG.baseValueEur} | Провизија: ${(CONFIG.platformFeePercent*100).toFixed(0)}%
## Безбедност: TLS 1.3+, PCI DSS, 2FA, токенизација
## Нивоа: ${CONFIG.levels.map(l => `${l.icon} ${l.name}: ${l.threshold}+ поени`).join(' | ')}
*Генерирано: ${new Date().toISOString()} | Верзија: 1.0.0*`;
      const blob = new Blob([specs], { type: 'text/markdown' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a'); a.href = url; a.download = 'MakedonEcoWorld_Specs.md'; a.click();
      URL.revokeObjectURL(url);
      showToast('Преземено!', 'Спецификациите се преземени. 📄', 'success');
    }
    function calculateEarnings() {
      const bottles = parseInt(document.getElementById('bottles')?.value) || 0;
      const cans = parseInt(document.getElementById('cans')?.value) || 0;
      const total = bottles + cans;
      const country = document.getElementById('country')?.value || 'global';
      const rates = { mk: 0.15, de: 0.25, no: 0.23, us: 0.10, global: 0.18 };
      const euroValue = (total * (rates[country] || rates.global)).toFixed(2);
      const resultEl = document.getElementById('resultValue'), pointsEl = document.getElementById('resultPoints');
      if (resultEl && pointsEl) { resultEl.textContent = `€${euroValue}`; pointsEl.textContent = total; resultEl.classList.add('result-pulse'); setTimeout(() => resultEl.classList.remove('result-pulse'), 2000); }
    }

    // ==================== GLOBAL MALLS LOGIC ====================
    const MALLS_DATA = [
      // АЗИЈА
      {region:'asia',country:'🇮🇳 Индија',name:'Phoenix Marketcity',city:'Мумбаи, Бангалор',visitors:'30M+',area:'1.4M m²',priority:'high',note:'Мулти-градска мрежа'},
      {region:'asia',country:'🇮🇳 Индија',name:'DLF Promenade & Select Citywalk',city:'Њу Делхи',visitors:'25M+',area:'1M m²',priority:'high',note:'Премиум локација'},
      {region:'asia',country:'🇨🇳 Кина',name:'New South China Mall',city:'Донггуан',visitors:'10M+',area:'0.9M m²',priority:'high',note:'Најголем мол во светот'},
