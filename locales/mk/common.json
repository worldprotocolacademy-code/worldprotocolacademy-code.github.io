      {region:'asia',country:'🇸🇬 Сингапур',name:'Marina Bay Sands',city:'Марина Беј',visitors:'28M+',area:'0.18M m²',priority:'high',note:'Интегриран ресорт'},
      {region:'asia',country:'🇹🇭 Тајланд',name:'CentralWorld',city:'Бангкок',visitors:'30M+',area:'0.55M m²',priority:'high',note:'Најголем во Тајланд'},
      {region:'asia',country:'🇲🇾 Малезија',name:'1Utama',city:'Куала Лумпур',visitors:'28M+',area:'0.5M m²',priority:'high',note:'Најголем во Малезија'},
      {region:'asia',country:'🇵🇭 Филипини',name:'SM Mall of Asia',city:'Манила',visitors:'30M+',area:'0.6M m²',priority:'high',note:'4-ти најголем во светот'},
      // АФРИКА
      {region:'africa',country:'🇿🇦 Јужна Африка',name:'Fourways Mall',city:'Јоханесбург',visitors:'15M+',area:'0.25M m²',priority:'high',note:'Експанзија во тек'},
      {region:'africa',country:'🇪🇬 Египет',name:'City Stars Mall',city:'Каиро',visitors:'20M+',area:'0.4M m²',priority:'high',note:'Најголем во Африка/Близок Исток'},
      {region:'africa',country:'🇳🇬 Нигерија',name:'Ikeja City Mall',city:'Лагос',visitors:'10M+',area:'0.15M m²',priority:'high',note:'Економски центар'},
      {region:'africa',country:'🇰🇪 Кенија',name:'Two Rivers Mall',city:'Најроби',visitors:'9M+',area:'0.15M m²',priority:'high',note:'Најголем во Источна Африка'},
      {region:'africa',country:'🇲🇦 Мароко',name:'Morocco Mall',city:'Казабланка',visitors:'12M+',area:'0.25M m²',priority:'high',note:'Најголем во Африка'},
      // СЕВЕРНА АМЕРИКА
      {region:'namerica',country:'🇺🇸 САД',name:'Mall of America',city:'Минесота',visitors:'40M+',area:'0.4M m²',priority:'critical',note:'Најпосетуван во САД'},
      {region:'namerica',country:'🇺🇸 САД',name:'King of Prussia Mall',city:'Пенсилванија',visitors:'22M+',area:'0.35M m²',priority:'high',note:'Најголем по површина'},
      {region:'namerica',country:'🇨🇦 Канада',name:'West Edmonton Mall',city:'Алберта',visitors:'28M+',area:'0.5M m²',priority:'critical',note:'Најголем во Канада'},
      {region:'namerica',country:'🇨🇦 Канада',name:'CF Toronto Eaton Centre',city:'Торонто',visitors:'30M+',area:'0.25M m²',priority:'high',note:'Најпосетуван во Канада'},
      {region:'namerica',country:'🇲🇽 Мексико',name:'Centro Santa Fe',city:'Мексико Сити',visitors:'25M+',area:'0.35M m²',priority:'high',note:'Најголем во Латинска Америка'},
      // ЈУЖНА АМЕРИКА
      {region:'samerica',country:'🇧🇷 Бразил',name:'Morumbi Shopping',city:'Сао Паоло',visitors:'22M+',area:'0.25M m²',priority:'high',note:'Економски центар'},
      {region:'samerica',country:'🇧🇷 Бразил',name:'Barra Shopping',city:'Рио де Жанеиро',visitors:'16M+',area:'0.2M m²',priority:'high',note:'Најголем во Рио'},
      {region:'samerica',country:'🇨🇱 Чиле',name:'Costanera Center',city:'Сантјаго',visitors:'22M+',area:'0.25M m²',priority:'critical',note:'Највисока зграда во Латинска Америка'},
      {region:'samerica',country:'🇨🇴 Колумбија',name:'Centro Comercial Andino',city:'Богота',visitors:'18M+',area:'0.15M m²',priority:'high',note:'Премиум локација'},
      {region:'samerica',country:'🇵🇪 Перу',name:'Jockey Plaza',city:'Лима',visitors:'15M+',area:'0.12M m²',priority:'high',note:'Јужна Лима, премиум сегмент'},
      // ОКЕАНИЈА
      {region:'oceania',country:'🇦🇺 Австралија',name:'Chadstone Shopping Centre',city:'Мелбурн',visitors:'30M+',area:'0.25M m²',priority:'critical',note:'Најголем на јужната полутопка'},
      {region:'oceania',country:'🇦🇺 Австралија',name:'Westfield Sydney',city:'Сиднеј',visitors:'25M+',area:'0.18M m²',priority:'high',note:'CBD локација'},
      {region:'oceania',country:'🇦🇺 Австралија',name:'Pacific Fair',city:'Gold Coast',visitors:'22M+',area:'0.2M m²',priority:'high',note:'Туристичка дестинација'},
      {region:'oceania',country:'🇳🇿 Нов Зеланд',name:'Sylvia Park',city:'Окланд',visitors:'15M+',area:'0.12M m²',priority:'high',note:'Најголем во Нов Зеланд'},
      // ОКЕАНИ / ОСТРОВСКИ
      {region:'oceans',country:'🌊 Тихи Океан',name:'Ala Moana Center',city:'Хонолулу, Хаваи',visitors:'25M+',area:'0.22M m²',priority:'critical',note:'Најголем open-air мол во светот'},
      {region:'oceans',country:'🌊 Индиски Океан',name:'The Grove',city:'Коломбо, Шри Ланка',visitors:'10M+',area:'0.12M m²',priority:'high',note:'Главен град, крајбрежен'},
      {region:'oceans',country:'🌊 Атлантски Океан',name:'Colombo Shopping Centre',city:'Лисабон, Португалија',visitors:'12M+',area:'0.18M m²',priority:'high',note:'Главен град, туристички раст'},
      {region:'oceans',country:'🌊 Арктички Океан',name:'Reykjavik Shopping',city:'Рејкјавик, Исланд',visitors:'4M+',area:'0.06M m²',priority:'medium',note:'Туристички раст, одржлив фокус'}
    ];

    let activeRegion = 'all';

    function getPriorityClass(p){
      switch(p){
        case 'critical': return 'priority-critical';
        case 'high': return 'priority-high';
        case 'medium': return 'priority-medium';
        default: return 'priority-low';
      }
    }
    function getPriorityLabel(p){
      switch(p){
        case 'critical': return '🔴 КРИТИЧЕН';
        case 'high': return '🟡 ВИСОК';
        case 'medium': return '🟢 СРЕДЕН';
        default: return '⚪ НИЗОК';
      }
    }

    function renderMalls(filter = ''){
      const grid = document.getElementById('mallGrid');
      if (!grid) return;
      grid.innerHTML = '';
      const lowerFilter = filter.toLowerCase();
      const filtered = MALLS_DATA.filter(m => {
        const matchRegion = activeRegion === 'all' || m.region === activeRegion;
        const matchSearch = !filter || m.name.toLowerCase().includes(lowerFilter) || m.country.toLowerCase().includes(lowerFilter) || m.city.toLowerCase().includes(lowerFilter) || m.note.toLowerCase().includes(lowerFilter);
        return matchRegion && matchSearch;
      });

      if(filtered.length === 0){
        grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:3rem;color:#666"><i class="fas fa-search" style="font-size:2rem;margin-bottom:1rem;display:block;opacity:.5"></i><span data-translate-key="malls_no_results">Нема пронајдени молови за твојот пребарување.</span></div>`;
        return;
      }

      filtered.forEach(m => {
        const card = document.createElement('div');
        card.className = 'mall-card';
        card.innerHTML = `
          <div class="mall-header">
            <div class="mall-name">${m.country} ${m.name}</div>
            <span class="mall-priority ${getPriorityClass(m.priority)}">${getPriorityLabel(m.priority)}</span>
          </div>
          <div class="mall-meta">
            <span><i class="fas fa-map-marker-alt"></i> ${m.city}</span>
            <span><i class="fas fa-users"></i> ${m.visitors} <span data-translate-key="malls_visitors">посетители</span></span>
            <span><i class="fas fa-ruler-combined"></i> ${m.area}</span>
          </div>
          <div class="mall-note">${m.note}</div>
          <div class="mall-region">🌍 <span data-translate-key="malls_region">Регион</span>: ${m.region.charAt(0).toUpperCase()+m.region.slice(1)}</div>
        `;
        grid.appendChild(card);
      });
    }

    // ==================== INIT ====================
    document.addEventListener('DOMContentLoaded', async () => {
      // Иницијализирај агенти и нивоа
      initAgents(); updateLevelProgress();
      
      // Иницијализирај калкулатор
      ['bottles', 'cans', 'country'].forEach(id => { const el = document.getElementById(id); if (el) { el.addEventListener('input', calculateEarnings); el.addEventListener('change', calculateEarnings); }});
      calculateEarnings();
      
      // Иницијализирај навигација
      document.querySelectorAll('nav a[href^="#"]').forEach(a => { a.addEventListener('click', e => { e.preventDefault(); document.querySelectorAll('nav a').forEach(l => l.classList.remove('active')); a.classList.add('active'); const target = document.querySelector(a.getAttribute('href')); if (target) { target.scrollIntoView({ behavior: 'smooth' }); if (a.getAttribute('href') === '#features') initMap(); }}); });
      
      // Иницијализирај модали
      document.querySelectorAll('.modal').forEach(modal => { modal.addEventListener('click', e => { if (e.target === modal) closeModal(modal.id); }); });
      document.addEventListener('keydown', e => { if (e.key === 'Escape') document.querySelectorAll('.modal.active').forEach(m => closeModal(m.id)); });
      
      // Иницијализирај глобални молови
      renderMalls();
      const tabs = document.querySelectorAll('.mall-tab');
      tabs.forEach(t => t.addEventListener('click', () => {
        tabs.forEach(x => x.classList.remove('active'));
        t.classList.add('active');
        activeRegion = t.dataset.region;
        renderMalls(document.getElementById('mallSearch')?.value || '');
      }));
      const search = document.getElementById('mallSearch');
      if (search) search.addEventListener('input', () => renderMalls(search.value));
      
      // Иницијализирај превод на елементите
      if (typeof window.ecoTranslateInstance !== 'undefined') {
        const elements = document.querySelectorAll('[data-translate-key]');
        if (elements.length > 0) {
          await window.ecoTranslateInstance.translateUI(Array.from(elements), window.ecoTranslateInstance.currentLang || 'mk');
        }
      }
      
      console.log('🌱', CONFIG.appName, 'initialized | 📧', CONFIG.contactEmail);
    });
    
    if ('serviceWorker' in navigator) { window.addEventListener('load', () => { console.log('🔧 Service Worker ready'); }); }
    window.addEventListener('resize', () => { const hideMobile = document.querySelectorAll('.hide-mobile'); if (window.innerWidth < 480) hideMobile.forEach(el => el.style.display = 'none'); else hideMobile.forEach(el => el.style.display = ''); });
    window.dispatchEvent(new Event('resize'));
  </script>
</body>
